    "@types/mdx": "^2.0.13",
    "@types/node": "22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "markdownlint-rule-relative-links": "^4.0.1",
    "eslint": "^8",
    "eslint-config-next": "15.1.7",
    "markdownlint-cli2": "^0.14.0",
